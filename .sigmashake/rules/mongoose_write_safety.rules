# mongoose_write_safety.rules
# Technology: mongoose | Capability: write

rule mongoose-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "$where"
  MESSAGE "Blocked an unsafe pattern in mongoose. Use the recommended best practices for 2025/2026."
}

rule mongoose-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "Model.remove"
  MESSAGE "You are using an outdated API for mongoose. Please upgrade to the newer API."
}
